# Copy to web/.env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://rxlms:PASSWORD@127.0.0.1:55432/rxlms?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://disruption.180p.org"
AUTH_TRUST_HOST=true

# Google OAuth (Google Cloud Console → Credentials → Web client)
# Authorized redirect URI: https://disruption.180p.org/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional — live AI mentor uses the local `claude` CLI, not this. Leave empty.
ANTHROPIC_API_KEY=""

# Auto-enroll new users into this course slug on first login
DEFAULT_COURSE_SLUG="disruption"

# Restrict registration to one email domain (empty = allow all), e.g. kse.org.ua
ALLOWED_EMAIL_DOMAIN=""
